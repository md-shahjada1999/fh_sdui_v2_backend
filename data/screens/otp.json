{
  "screenId": "otp",
  "tokens": {},
  "styles": {},
  "apis": {
    "verifyOtp": {
      "method": "POST",
      "url": "/api/auth/verify-otp",
      "body": { "mobile": "{{state.mobile}}", "otp": "{{form.otp}}" },
      "store": "verifyOtpResponse"
    },
    "resendOtp": {
      "method": "POST",
      "url": "/api/auth/send-otp",
      "body": { "mobile": "{{state.mobile}}" },
      "store": "resendOtpResponse"
    }
  },
  "actions": {},
  "components": {},
  "layout": {
    "type": "screen",
    "style": [".layout.screenPadded"],
    "children": [
      {
        "type": "expanded",
        "children": [
          {
            "type": "scroll",
            "children": [
              {
                "type": "column",
                "inlineStyle": { "crossAxisAlignment": "start" },
                "children": [
                  { "type": "spacer", "props": { "height": 80 } },
                  {
                    "type": "text",
                    "props": { "text": "Enter OTP" },
                    "style": [".layout.heading"]
                  },
                  { "type": "spacer", "props": { "height": 12 } },
                  {
                    "type": "text",
                    "props": { "text": "An OTP has been sent to the\nbelow mobile number" },
                    "style": [".layout.subtitle"]
                  },
                  { "type": "spacer", "props": { "height": 16 } },
                  {
                    "type": "row",
                    "inlineStyle": { "gap": 8, "crossAxisAlignment": "center" },
                    "children": [
                      {
                        "type": "text",
                        "props": { "text": "{{state.mobile}}" },
                        "inlineStyle": { "fontSize": "#typography.label", "fontWeight": "w600", "color": "#colors.textPrimary" }
                      },
                      {
                        "type": "text",
                        "props": { "text": "edit" },
                        "inlineStyle": { "fontSize": "#typography.body", "color": "#colors.primary" },
                        "actions": [{ "event": "onClick", "type": "pop" }]
                      }
                    ]
                  },
                  { "type": "spacer", "props": { "height": 24 } },
                  {
                    "type": "otp_input",
                    "props": { "name": "otp", "length": 6 }
                  },
                  { "type": "spacer", "props": { "height": 20 } },
                  {
                    "type": "rich_text",
                    "props": {
                      "spans": [
                        { "text": "Didn't get the OTP? ", "style": { "color": "#colors.textSecondary", "fontSize": "#typography.bodySmall" } },
                        {
                          "text": "Resend",
                          "style": { "color": "#colors.primary", "fontSize": "#typography.bodySmall", "fontWeight": "w600" },
                          "actions": [
                            {
                              "type": "api",
                              "target": "resendOtp",
                              "onSuccess": {
                                "type": "toast",
                                "props": { "message": "OTP resent successfully" }
                              },
                              "onFail": {
                                "type": "toast",
                                "props": { "message": "Failed to resend OTP" }
                              }
                            }
                          ]
                        }
                      ]
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      { "type": "spacer", "props": { "height": 16 } },
      {
        "type": "button",
        "props": { "text": "Confirm" },
        "style": [".buttons.primary"],
        "inlineStyle": { "width": 1000 },
        "enabled": "{{form.otp.length >= 6}}",
        "actions": [
          {
            "event": "onClick",
            "type": "api",
            "target": "verifyOtp",
            "onSuccess": {
              "type": "chain",
              "actions": [
                { "type": "storeToken", "props": { "key": "auth_token", "value": "{{verifyOtpResponse.data.token}}" } },
                { "type": "setState", "props": { "key": "state.loggedIn", "value": true } },
                { "type": "navigate", "props": { "route": "/dashboard", "replace": true } }
              ]
            },
            "onFail": {
              "type": "toast",
              "props": { "message": "{{_error.verifyOtp.message}}" }
            }
          }
        ]
      },
      { "type": "spacer", "props": { "height": 24 } }
    ]
  }
}
