{
  "screenId": "login",
  "tokens": {},
  "styles": {},
  "apis": {
    "sendOtp": {
      "method": "POST",
      "url": "/api/auth/send-otp",
      "body": {
        "mobile": "{{form.mobile}}"
      }
    }
  },
  "actions": {},
  "components": {},
  "layout": {
    "type": "screen",
    "style": [".layout.screenPadded"],
    "inlineStyle": { "backgroundColor": "#colors.background" },
    "children": [
      {
        "type": "spacer",
        "props": { "height": 60 }
      },
      {
        "type": "image",
        "props": { "url": "https://flip.health/assets/images/logo-light.png" },
        "inlineStyle": { "width": 120, "height": 120, "borderRadius": 20 }
      },
      {
        "type": "spacer",
        "props": { "height": 32 }
      },
      {
        "type": "text",
        "props": { "text": "Welcome Backkkkkkkk" },
        "inlineStyle": {
          "fontSize": "#typography.h1",
          "fontWeight": "bold",
          "color": "#colors.textPrimary"
        }
      },
      {
        "type": "text",
        "props": { "text": "Enter your mobile number to continue" },
        "inlineStyle": {
          "fontSize": "#typography.body",
          "color": "#colors.textSecondary",
          "padding": { "top": 8, "bottom": 0, "left": 0, "right": 0 }
        }
      },
      {
        "type": "spacer",
        "props": { "height": 32 }
      },
      {
        "type": "input",
        "props": {
          "name": "mobile",
          "placeholder": "Mobile Number",
          "keyboardType": "phone",
          "maxLength": 10
        },
        "style": [".inputs.field"]
      },
      {
        "type": "spacer",
        "props": { "height": 16 }
      },
      {
        "type": "checkbox",
        "props": {
          "name": "terms",
          "label": "I agree to the Terms & Conditions"
        }
      },
      {
        "type": "spacer",
        "props": { "height": 24 }
      },
      {
        "type": "button",
        "props": { "text": "Continue" },
        "style": [".buttons.primary"],
        "inlineStyle": { "width": 1000 },
        "enabled": "{{form.terms && form.mobile.length >= 10}}",
        "actions": [
          {
            "event": "onSubmit",
            "type": "chain",
            "actions": [
              {
                "type": "setState",
                "props": { "key": "state.mobile", "value": "{{form.mobile}}" }
              },
              {
                "type": "api",
                "target": "sendOtp",
                "onSuccess": {
                  "type": "navigate",
                  "props": { "route": "/otp" }
                },
                "onFail": {
                  "type": "toast",
                  "props": { "message": "{{_error.sendOtp.message}}" }
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
